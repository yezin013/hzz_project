version: 1
applications:
  - appRoot: frontend
    frontend:
      phases:
        preBuild:
          commands:
            - export AMPLIFY_BUILD=true
            - npm ci
            - env | grep -e NEXTAUTH_ -e COGNITO_ -e NEXT_PUBLIC_ >> .env.production || true

        build:
          commands:
            - npm run build
      artifacts:
        baseDirectory: .
        files:
          - '.next/**/*'
          - 'public/**/*'
          - 'package.json'
          - 'next.config.ts'
          - '.env.production'
